{
  "name": "collab-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "mock:pages": "node mock-pages/server.js",
    "mock:tables": "node mock-tables/server.js",
    "proto": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:src/proto --grpc_out=grpc_js:src/proto --proto_path=proto proto/pages.proto"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0",
    "@hocuspocus/server": "^2.13.0",
    "@types/jsonwebtoken": "^9.0.10",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
